# Gloss server config. Copy to .env and fill in. .env is gitignored;
# this template is safe to commit. Pick ONE of the two modes below.

GLOSS_OWNER=your-github-username
GLOSS_REPO=your-repo
# Optional; defaults to main
# GLOSS_BRANCH=main

# --- Mode A: single-user (Personal Access Token) ---------------------------
# A fine-grained PAT with Contents: Read and write on the target repo:
#   https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=github_pat_xxxxxxxx

# --- Mode B: multi-user (GitHub OAuth) -------------------------------------
# Register an OAuth App at https://github.com/settings/developers
#   Homepage URL:               http://localhost:5173
#   Authorization callback URL: http://localhost:5173/auth/callback
# Then set these (and comment out GITHUB_TOKEN above — OAuth takes precedence):
# GLOSS_OAUTH_CLIENT_ID=Iv1.xxxxxxxx
# GLOSS_OAUTH_CLIENT_SECRET=xxxxxxxx
# GLOSS_BASE_URL=http://localhost:5173      # the app origin (OAuth callback base)
# GLOSS_OAUTH_SCOPE=repo                      # 'repo' for private, 'public_repo' for public

