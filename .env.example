# Gloss live-git config (Phase 2). Copy to .env and fill in.
# .env is gitignored; this template is safe to commit.
#
# Create a fine-grained PAT with Contents: Read and write on the target repo:
#   https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=github_pat_xxxxxxxx
GLOSS_OWNER=your-github-username
GLOSS_REPO=your-repo
# Optional; defaults to main
# GLOSS_BRANCH=main
